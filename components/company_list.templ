package components

import "internship-manager/internal/db"

templ CompanyList(companies []db.Company) {
	@Layout("Companies") {
		<div class="flex justify-between items-center mb-6">
			<h2 class="text-2xl font-bold">Companies</h2>
		</div>
		
		@AddCompanyForm()

		<div id="company-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			for _, company := range companies {
				@CompanyCard(company)
			}
		</div>
	}
}
